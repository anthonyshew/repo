{
	"name": "shewrepo",
	"version": "0.1.0",
	"scripts": {
		"build": "turbo run build",
		"clean": "find . -name node_modules -o -name .next -o -name dist -o -name .contentlayer -type d -prune | xargs rm -rf",
		"dev": "turbo run dev",
		"dev:ts": "tsc -b -w --preserveWatchOutput",
		"lint": "oxlint --type-aware .",
		"lint:fix": "oxlint --type-aware --fix --fix-suggestions .",
		"format": "oxfmt --check .",
		"format:fix": "oxfmt .",
		"check-types": "turbo run check-types --continue",
		"knip": "knip"
	},
	"devDependencies": {
		"knip": "^5.61.3",
		"oxfmt": "^0.57.0",
		"oxlint": "^1.72.0",
		"oxlint-tsgolint": "^0.24.0",
		"turbo": "^2.5.4",
		"typescript": "^5.8.3"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
