{
	"name": "@repo/ui",
	"version": "0.1.0",
	"private": true,
	"files": [
		"dist"
	],
	"sideEffects": [
		"**/*.css"
	],
	"imports": {
		"#/*": "./src/*.ts"
	},
	"exports": {
		"./*": {
			"types": "./dist/components/*.d.ts",
			"default": "./src/components/*.tsx"
		},
		"./styles.css": "./dist/index.css"
	},
	"scripts": {
		"dev": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch --optimize --minify",
		"build": "tailwindcss -i ./src/styles.css -o ./dist/index.css --optimize --minify",
		"check-types": "tsc -b"
	},
	"dependencies": {
		"@radix-ui/react-avatar": "^1.2.1",
		"clsx": "^2.1.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@repo/tsconfig": "workspace:*",
		"@tailwindcss/cli": "^4.3.2",
		"@types/react": "^19.2.17",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"next": "^15 || ^16"
	}
}
